# ───────── Contact form email (Resend) — REQUIRED for the form to send ─────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
QUOTE_TO_EMAIL=you@roamprints.com               # where print requests get delivered
QUOTE_FROM_EMAIL=requests@your-verified-domain  # sender; must be on a Resend-verified domain
                                                # (for quick testing you can use onboarding@resend.dev,
                                                #  but it only delivers to the Resend account owner)

# ───────── File uploads (Vercel Blob) — OPTIONAL ─────────
# Don't set this by hand. When you create a Blob store in the Vercel dashboard
# (Storage → Create → Blob) and connect it to the project, Vercel injects
# BLOB_READ_WRITE_TOKEN automatically. The form still works without it —
# people can paste a reference link instead.

# ───────── Stripe (optional) ─────────
# For Stripe Payment Links, you do not need env vars here.
# Add each product's Stripe URL directly to SHOP_ITEMS in build.py as `buy_url`.
